{
  "name": "react-web3-icons",
  "version": "3.0.0",
  "description": "React SVG icon library for Web3 — blockchains, wallets, DEXs, tokens, and more",
  "license": "MIT",
  "author": "derodero24",
  "keywords": [
    "react",
    "web3",
    "icon",
    "svg",
    "blockchain",
    "cryptocurrency",
    "crypto",
    "token",
    "coin",
    "nft",
    "defi",
    "dex",
    "bridge",
    "exchange",
    "explorer",
    "marketplace",
    "wallet",
    "ethereum",
    "solana",
    "layer2",
    "l2"
  ],
  "type": "module",
  "repository": "github:derodero24/react-web3-icons",
  "homepage": "https://react-web3-icons.vercel.app/",
  "main": "dist/index.mjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./bridge": {
      "types": "./dist/bridge/index.d.mts",
      "default": "./dist/bridge/index.mjs"
    },
    "./deprecated": {
      "import": {
        "types": "./dist/deprecated.d.mts",
        "default": "./dist/deprecated.mjs"
      },
      "require": {
        "types": "./dist/deprecated.d.cts",
        "default": "./dist/deprecated.cjs"
      }
    },
    "./chain": {
      "types": "./dist/chain/index.d.mts",
      "default": "./dist/chain/index.mjs"
    },
    "./coin": {
      "types": "./dist/coin/index.d.mts",
      "default": "./dist/coin/index.mjs"
    },
    "./defi": {
      "types": "./dist/defi/index.d.mts",
      "default": "./dist/defi/index.mjs"
    },
    "./devtool": {
      "types": "./dist/devtool/index.d.mts",
      "default": "./dist/devtool/index.mjs"
    },
    "./dex": {
      "types": "./dist/dex/index.d.mts",
      "default": "./dist/dex/index.mjs"
    },
    "./domain": {
      "types": "./dist/domain/index.d.mts",
      "default": "./dist/domain/index.mjs"
    },
    "./exchange": {
      "types": "./dist/exchange/index.d.mts",
      "default": "./dist/exchange/index.mjs"
    },
    "./explorer": {
      "types": "./dist/explorer/index.d.mts",
      "default": "./dist/explorer/index.mjs"
    },
    "./marketplace": {
      "types": "./dist/marketplace/index.d.mts",
      "default": "./dist/marketplace/index.mjs"
    },
    "./node": {
      "types": "./dist/node/index.d.mts",
      "default": "./dist/node/index.mjs"
    },
    "./portfolio": {
      "types": "./dist/portfolio/index.d.mts",
      "default": "./dist/portfolio/index.mjs"
    },
    "./storage": {
      "types": "./dist/storage/index.d.mts",
      "default": "./dist/storage/index.mjs"
    },
    "./tracker": {
      "types": "./dist/tracker/index.d.mts",
      "default": "./dist/tracker/index.mjs"
    },
    "./wallet": {
      "types": "./dist/wallet/index.d.mts",
      "default": "./dist/wallet/index.mjs"
    },
    "./meta": {
      "types": "./dist/meta/index.d.mts",
      "default": "./dist/meta/index.mjs"
    },
    "./dynamic": {
      "types": "./dist/dynamic/index.d.mts",
      "default": "./dist/dynamic/index.mjs"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "analyze": "size-limit --why",
    "build": "tsdown",
    "check": "biome ci",
    "format": "biome format --write",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "prepare": "lefthook install",
    "prepublishOnly": "pnpm run build",
    "optimize:svg": "svgo --config svgo.config.js",
    "size": "size-limit",
    "start": "tsdown --watch",
    "test": "vitest run",
    "test:visual": "vitest run --config vitest.config.visual.ts",
    "test:visual:update": "vitest run --config vitest.config.visual.ts --update",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.29.8",
    "@size-limit/preset-small-lib": "^12.0.0",
    "@tsconfig/strictest": "^2.0.8",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/browser": "^4.0.18",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "jsdom": "^28.1.0",
    "lefthook": "^2.1.1",
    "playwright": "^1.58.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "size-limit": "^12.0.0",
    "svgo": "^4.0.1",
    "tsdown": "0.21.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "vitest-browser-react": "^2.0.5"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "packageManager": "pnpm@10.31.0",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "size-limit": [
    {
      "name": "full bundle",
      "path": "dist/index.mjs",
      "limit": "137 KB"
    },
    {
      "name": "deprecated",
      "path": "dist/deprecated.mjs",
      "limit": "1 KB"
    },
    {
      "name": "bridge",
      "path": "dist/bridge/index.mjs",
      "limit": "10 KB"
    },
    {
      "name": "chain",
      "path": "dist/chain/index.mjs",
      "limit": "28 KB"
    },
    {
      "name": "coin",
      "path": "dist/coin/index.mjs",
      "limit": "55 KB"
    },
    {
      "name": "defi",
      "path": "dist/defi/index.mjs",
      "limit": "8 KB"
    },
    {
      "name": "devtool",
      "path": "dist/devtool/index.mjs",
      "limit": "20 KB"
    },
    {
      "name": "dex",
      "path": "dist/dex/index.mjs",
      "limit": "12 KB"
    },
    {
      "name": "domain",
      "path": "dist/domain/index.mjs",
      "limit": "5 KB"
    },
    {
      "name": "exchange",
      "path": "dist/exchange/index.mjs",
      "limit": "10 KB"
    },
    {
      "name": "explorer",
      "path": "dist/explorer/index.mjs",
      "limit": "10 KB"
    },
    {
      "name": "marketplace",
      "path": "dist/marketplace/index.mjs",
      "limit": "15 KB"
    },
    {
      "name": "node",
      "path": "dist/node/index.mjs",
      "limit": "5 KB"
    },
    {
      "name": "portfolio",
      "path": "dist/portfolio/index.mjs",
      "limit": "10 KB"
    },
    {
      "name": "storage",
      "path": "dist/storage/index.mjs",
      "limit": "20 KB"
    },
    {
      "name": "tracker",
      "path": "dist/tracker/index.mjs",
      "limit": "10 KB"
    },
    {
      "name": "wallet",
      "path": "dist/wallet/index.mjs",
      "limit": "20 KB"
    },
    {
      "name": "meta",
      "path": "dist/meta/index.mjs",
      "limit": "1 KB"
    }
  ]
}
